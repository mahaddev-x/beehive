{
  "name": "beehive-cli",
  "version": "0.5.2",
  "description": "Local-first parallel AI agent swarm runner, built on pi-agent",
  "type": "module",
  "bin": {
    "beehive": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "postinstall": "node scripts/remove-ps1.js",
    "postlink": "node scripts/remove-ps1.js"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.65.2",
    "@mariozechner/pi-ai": "^0.65.2",
    "@mariozechner/pi-tui": "^0.65.2",
    "@mozilla/readability": "^0.5.0",
    "chalk": "^5.4.1",
    "commander": "^12.0.0",
    "csv-parse": "^5.6.0",
    "linkedom": "^0.18.12",
    "p-limit": "^6.2.0",
    "smol-toml": "^1.3.1",
    "tsx": "^4.19.3",
    "turndown": "^7.2.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/mozilla__readability": "^0.4.2",
    "@types/node": "^22.15.3",
    "@types/turndown": "^5.0.5",
    "shx": "^0.3.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
